{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:app:default",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-close",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-is-maximized",
    "core:window:allow-is-visible",
    "core:window:allow-start-dragging",
    "core:window:allow-set-focus",
    "opener:default",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "https://api-v2.soundcloud.com/*" },
        { "url": "https://*.sndcdn.com/*" },
        { "url": "https://cf-hls-media.sndcdn.com/*" },
        { "url": "https://cf-hls-opus-media.sndcdn.com/*" },
        { "url": "https://cf-media.sndcdn.com/*" },
        { "url": "https://lrclib.net/*" },
        { "url": "https://symptom-lyrics.xn0tdev.workers.dev/*" }
      ]
    },
    "fs:allow-document-read-recursive",
    "fs:allow-document-write-recursive",
    "fs:allow-document-meta-recursive",
    "updater:default",
    "process:allow-restart",
    "process:allow-exit"
  ]
}
