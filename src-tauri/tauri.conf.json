{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "spotycloud",
  "version": "0.4.0",
  "identifier": "com.spotycloud.app",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "SpotyCloud",
        "width": 1200,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDMwN0ZCNzkzNDhFMzAzMgpSV1F5TUk0MGVmc0hBN3IvcTVjeWhaaEFzUFBGRTVFUDREVkJDVC8zbUNwdlBDbUs1RWZBTHBxUQo=",
      "endpoints": [
        "https://github.com/aasm3535/SpotyCloud/releases/latest/download/latest.json"
      ]
    }
  },
  "capabilities": [
    {
      "identifier": "default",
      "description": "Default capabilities for the app",
      "windows": ["main"],
      "permissions": [
        "core:default",
        "fs:default",
        "http:default",
        "global-shortcut:default",
        "global-shortcut:allow-is-registered",
        "global-shortcut:allow-register",
        "global-shortcut:allow-unregister",
        "global-shortcut:allow-unregister-all"
      ]
    }
  ]
}
